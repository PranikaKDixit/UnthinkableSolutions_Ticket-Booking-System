# ── Server ──────────────────────────────────────────────────────────
PORT=5000

# ── Database (PostgreSQL) ───────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ticketing"

# ── Auth ────────────────────────────────────────────────────────────
# Use a long, random string in production.
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES="7d"

# ── Seat holds & waitlist offers ────────────────────────────────────
HOLD_TTL_SECONDS=600        # how long a seat stays HELD before auto-release (10 min)
OFFER_TTL_SECONDS=600       # how long a waitlist offer link stays valid (10 min)
SWEEP_INTERVAL_SECONDS=30   # how often the TTL sweeper runs

# ── Frontend / CORS ─────────────────────────────────────────────────
CORS_ORIGIN="http://localhost:5173"
FRONTEND_URL="http://localhost:5173"   # used to build waitlist offer links in emails

# ── Branding ────────────────────────────────────────────────────────
APP_NAME="CineSeat"

# ── Email (SMTP) ────────────────────────────────────────────────────
# Leave SMTP_HOST blank to auto-use a free Ethereal test inbox in dev
# (each send logs a preview URL). Set these for real delivery
# (Gmail, Mailtrap, SendGrid SMTP, Brevo, etc — any free tier).
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="CineSeat <no-reply@cineseat.app>"
